# OpenAPI Spec Verifier Configuration
# Copy this file to .env and fill in your credentials

# POLITEMall Session Cookies (from browser dev tools)
D2L_SESSION_VAL=your_session_value_here
D2L_SECURE_SESSION_VAL=your_secure_session_value_here

# Brightspace JWT Token (from browser dev tools)
D2L_FETCH_TOKEN=your_jwt_token_here
